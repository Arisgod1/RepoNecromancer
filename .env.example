# =============================================================================
# RepoNecromancer 环境变量配置
# =============================================================================
# 复制此文件为 .env，或直接设置环境变量后运行
# 注意：Viper 不会自动读取 .env 文件，需通过 source 或 export 加载
#       或者通过 NECRO_CONFIG 指定配置文件路径
#
# 用法：
#   cp .env.example .env
#   # 编辑 .env 填入你的密钥
#   source .env && go run ./cmd/necro/main.go ...
# =============================================================================

# -----------------------------------------------------------------------------
# 必需：API 密钥
# -----------------------------------------------------------------------------

# GitHub Personal Access Token (Classic)
# 用于访问 GitHub API，需具备 repo 和 read:user 权限
# 生成地址：https://github.com/settings/tokens
# 格式：ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_TOKEN=

# DashScope API Key（用于 LLM 推理）
# 用于尸检原因分析（sample/full 模式）
# 获取地址：https://dashscope.console.aliyun.com/apiKey
# 格式：sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DASHSCOPE_API_KEY=

# -----------------------------------------------------------------------------
# 可选：配置文件路径
# -----------------------------------------------------------------------------

# 指定配置文件路径（默认为当前目录或 ./configs 下的 config.yaml）
# 如果设置，将忽略默认路径
# NECRO_CONFIG=/path/to/config.yaml

# -----------------------------------------------------------------------------
# 可选：LLM 配置
# -----------------------------------------------------------------------------

# DashScope 模型名称（默认为 qwen3.6-flash）
# DASHSCOPE_MODEL=qwen3.6-flash

# DashScope API 地址（默认为阿里云 DashScope 兼容端点）
# DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# -----------------------------------------------------------------------------
# 可选：应用配置（可通过 config.yaml 覆盖）
# -----------------------------------------------------------------------------

# 日志级别：debug / info / warn / error（默认为 info）
# NECRO_LOG_LEVEL=info

# 输出目录（默认为 ./out）
# NECRO_APP_OUTPUT_DIR=./out

# 缓存目录（默认为 ./.cache/necro）
# NECRO_APP_CACHE_DIR=./.cache/necro

# 默认语言：zh / en（默认为 zh）
# NECRO_APP_LANGUAGE=zh

# -----------------------------------------------------------------------------
# 可选：分析配置
# -----------------------------------------------------------------------------

# 默认不活跃年限（默认为 3）
# NECRO_ANALYSIS_DEFAULT_YEARS=3

# 最小星数（默认为 5000）
# NECRO_ANALYSIS_MIN_STARS=5000

# 最大 items 数（默认为 500）
# NECRO_ANALYSIS_MAX_ITEMS=500

# 最大证据数（默认为 250）
# NECRO_ANALYSIS_MAX_EVIDENCE=250

# -----------------------------------------------------------------------------
# 可选：查询预算
# -----------------------------------------------------------------------------

# 最大查询轮次（默认为 16）
# NECRO_QUERY_MAX_TURNS=16

# 最大 token 数（0 表示不限）
# NECRO_QUERY_MAX_TOKENS=0

# 最大成本（0 表示不限）
# NECRO_QUERY_MAX_COST=0

# -----------------------------------------------------------------------------
# 可选：网络配置
# -----------------------------------------------------------------------------

# HTTP 超时（毫秒，默认 12000）
# NECRO_NETWORK_TIMEOUT_MS=12000

# 最大重试次数（默认为 3）
# NECRO_NETWORK_RETRY_MAX=3

# 退避基础时间（毫秒，默认 300）
# NECRO_NETWORK_BACKOFF_BASE_MS=300

# 允许的域名列表（逗号分隔，默认 github.com,api.github.com）
# NECRO_NETWORK_ALLOW_DOMAINS=github.com,api.github.com

# 阻止的域名列表（逗号分隔）
# NECRO_NETWORK_BLOCK_DOMAINS=

# 是否拒绝私有网络（默认为 true）
# NECRO_NETWORK_DENY_PRIVATE_NETWORKS=true

# -----------------------------------------------------------------------------
# 可选：权限配置
# -----------------------------------------------------------------------------

# 权限模式：default / permissive / restrictive / allowlist / denylist / none
# 默认为 default
# NECRO_PERMISSIONS_MODE=default

# -----------------------------------------------------------------------------
# 可选：工具配置
# -----------------------------------------------------------------------------

# 禁用的工具列表（逗号分隔）
# NECRO_TOOLS_DENY=
